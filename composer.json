{
    "name": "tyamahori/laravel-plain-sqs",
    "type": "library",
    "description": "Custom SQS connector for Laravel that supports custom format JSON",
    "keywords": [
        "php",
        "laravel",
        "lumen",
        "sqs",
        "aws"
    ],
    "homepage": "https://github.com/tyamahori/laravel-plain-sqs",
    "license": "MIT",
    "authors": [
        {
            "name": "Kazuki Tamahori",
            "email": "tyamahori@gmail.com",
            "homepage": "https://www.tyamahori.com"
        }
    ],
    "require": {
        "php": "^8.3|^8.4|^8.5",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/bus": "^11.0|^12.0|^13.0",
        "aws/aws-sdk-php": "~3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0|^12.5|^13.0",
        "orchestra/testbench": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Tyamahori\\PlainSqs\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tyamahori\\PlainSqs\\Integrations\\LaravelServiceProvider"
            ]
        }
    }
}
